{
  "name": "@fluent/content-linter",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "content-linter": "./dist/cli.js"
  },
  "scripts": {
    "build": "esbuild src/cli.ts --bundle --platform=node --target=node20 --outfile=dist/cli.js",
    "dev": "echo 'content-linter: no dev server (run: node dist/cli.js <exercise-folder>)'",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "esbuild": "^0.21.0",
    "tsx": "^4.15.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
