// This is your Prisma schema file per data-model.md (11 tables)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email         String   @unique
  name          String?
  image         String?
  emailVerified DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  accounts      Account[]
  sessions      Session[]
  enrollments   Enrollment[]
  submissions   Submission[]
  masteryEvents MasteryEvent[]
  credentials   Credential[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @db.Uuid
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String   @db.Uuid
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Track {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug        String   @unique
  title       String
  description String
  language    String
  status      TrackStatus @default(draft)
  createdAt   DateTime @default(now())

  concepts    Concept[]
  enrollments Enrollment[]
  credentials Credential[]

  @@map("tracks")
}

enum TrackStatus {
  coming_soon
  draft
  published
}

model Concept {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  trackId         String   @db.Uuid
  slug            String
  title           String
  position        Int
  lessonAvgTimeMs Int?
  hasTestout      Boolean  @default(false)
  status          ConceptStatus @default(wip)
  prereqConceptId String?  @db.Uuid
  createdAt       DateTime @default(now())

  track           Track    @relation(fields: [trackId], references: [id])
  prereq          Concept? @relation("ConceptPrereq", fields: [prereqConceptId], references: [id])
  dependents      Concept[] @relation("ConceptPrereq")
  exercises       Exercise[]
  conceptStates   ConceptState[]
  submissions     Submission[]
  masteryEvents   MasteryEvent[]

  @@unique([trackId, slug])
  @@unique([trackId, position])
  @@map("concepts")
}

enum ConceptStatus {
  wip
  published
}

model Exercise {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conceptId   String   @db.Uuid
  type        ExerciseType
  contentPath String
  createdAt   DateTime @default(now())

  concept     Concept  @relation(fields: [conceptId], references: [id])
  submissions Submission[]

  @@map("exercises")
}

enum ExerciseType {
  lesson
  testout
  placement
}

model Enrollment {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String   @db.Uuid
  trackId       String   @db.Uuid
  startedAt     DateTime @default(now())
  completedAt   DateTime?

  user          User     @relation(fields: [userId], references: [id])
  track         Track    @relation(fields: [trackId], references: [id])
  conceptStates ConceptState[]
  masteryEvents MasteryEvent[]
  capstoneSessions CapstoneSessions[]

  @@unique([userId, trackId])
  @@map("enrollments")
}

model ConceptState {
  id           String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  enrollmentId String       @db.Uuid
  conceptId    String       @db.Uuid
  state        LearnerState @default(locked)
  achievedVia  AchievedVia?
  openedAt     DateTime?
  masteredAt   DateTime?
  updatedAt    DateTime     @updatedAt

  enrollment   Enrollment   @relation(fields: [enrollmentId], references: [id])
  concept      Concept      @relation(fields: [conceptId], references: [id])

  @@unique([enrollmentId, conceptId])
  @@index([enrollmentId])
  @@index([conceptId])
  @@map("concept_states")
}

enum LearnerState {
  locked
  available
  in_progress
  mastered
  completed
}

enum AchievedVia {
  placement
  test_out
  lesson
}

model Submission {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String   @db.Uuid
  conceptId   String   @db.Uuid
  exerciseId  String?  @db.Uuid
  code        String
  language    String   @default("go")
  stdout      String?
  stderr      String?
  exitCode    Int?
  runtimeMs   Int?
  timedOut    Boolean  @default(false)
  isSuite     Boolean  @default(false)
  passed      Boolean?
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id])
  concept     Concept  @relation(fields: [conceptId], references: [id])
  exercise    Exercise? @relation(fields: [exerciseId], references: [id])

  @@index([userId, conceptId, createdAt(sort: Desc)])
  @@map("submissions")
}

model MasteryEvent {
  id              String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  enrollmentId    String      @db.Uuid
  conceptId       String      @db.Uuid
  userId          String      @db.Uuid
  achievedVia     AchievedVia
  lessonAvgTimeMs Int?
  createdAt       DateTime    @default(now())

  enrollment      Enrollment  @relation(fields: [enrollmentId], references: [id])
  concept         Concept     @relation(fields: [conceptId], references: [id])
  user            User        @relation(fields: [userId], references: [id])

  @@index([enrollmentId])
  @@map("mastery_events")
}

model CapstoneSessions {
  id                   String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId               String   @db.Uuid
  enrollmentId         String   @db.Uuid
  currentStep          Int      @default(1)
  k8sJobName           String?
  dbConnectionEncrypted String?
  dbProvisionedAt      DateTime?
  dbExpiresAt          DateTime?
  lastActiveAt         DateTime @default(now())
  startedAt            DateTime @default(now())
  completedAt          DateTime?

  enrollment           Enrollment @relation(fields: [enrollmentId], references: [id])
  stepCompletions      CapstoneStepCompletion[]

  @@map("capstone_sessions")
}

model CapstoneStepCompletion {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sessionId          String   @db.Uuid
  stepNumber         Int
  completedAt        DateTime @default(now())
  verificationResult Json

  session            CapstoneSessions @relation(fields: [sessionId], references: [id])

  @@unique([sessionId, stepNumber])
  @@map("capstone_step_completions")
}

model Credential {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @db.Uuid
  trackId   String   @db.Uuid
  token     String   @unique
  summary   Json
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
  track     Track    @relation(fields: [trackId], references: [id])

  @@map("credentials")
}
