{
  "name": "@fluent/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "dotenv -e ../../.env.local -- tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "dotenv -e ../../.env.local -- vitest run",
    "test:watch": "dotenv -e ../../.env.local -- vitest",
    "db:generate": "dotenv -e ../../.env.local -- prisma generate",
    "db:migrate": "dotenv -e ../../.env.local -- prisma migrate dev",
    "db:migrate:deploy": "dotenv -e ../../.env.local -- prisma migrate deploy",
    "db:seed": "dotenv -e ../../.env.local -- prisma db seed"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.0",
    "@prisma/client": "^5.15.0",
    "@temporalio/client": "^1.10.0",
    "@trpc/server": "^11.0.0",
    "bullmq": "^5.0.0",
    "fastify": "^4.28.0",
    "ioredis": "^5.4.0",
    "next-auth": "^5.0.0-beta.19",
    "pino": "^9.3.0",
    "pino-http": "^10.2.0",
    "prom-client": "^15.1.0",
    "superjson": "^2.2.0",
    "zod": "^3.23.0"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "prisma": "^5.15.0",
    "tsx": "^4.15.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
