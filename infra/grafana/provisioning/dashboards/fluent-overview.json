{
  "title": "Fluent Overview",
  "uid": "fluent-overview",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Executions / min",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "rate(fluent_sandbox_executions_total[1m]) * 60",
          "legendFormat": "{{status}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 2 } }
      }
    },
    {
      "id": 2,
      "title": "Execution p95 latency (s)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "histogram_quantile(0.95, rate(fluent_sandbox_execution_duration_seconds_bucket[5m]))",
          "legendFormat": "p95"
        },
        {
          "datasource": { "type": "prometheus" },
          "expr": "histogram_quantile(0.50, rate(fluent_sandbox_execution_duration_seconds_bucket[5m]))",
          "legendFormat": "p50"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "lineWidth": 2 } }
      }
    },
    {
      "id": 3,
      "title": "Error rate",
      "type": "stat",
      "gridPos": { "x": 0, "y": 8, "w": 6, "h": 4 },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "rate(fluent_sandbox_executions_total{status=\"failure\"}[5m]) / rate(fluent_sandbox_executions_total[5m])",
          "legendFormat": "Error rate"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Success rate",
      "type": "stat",
      "gridPos": { "x": 6, "y": 8, "w": 6, "h": 4 },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "rate(fluent_sandbox_executions_total{status=\"success\"}[5m]) / rate(fluent_sandbox_executions_total[5m])",
          "legendFormat": "Success rate"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.9 },
              { "color": "green", "value": 0.95 }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "title": "Active workers",
      "type": "stat",
      "gridPos": { "x": 12, "y": 8, "w": 6, "h": 4 },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "fluent_sandbox_active_workers",
          "legendFormat": "Workers"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    },
    {
      "id": 6,
      "title": "Sandbox logs",
      "type": "logs",
      "gridPos": { "x": 0, "y": 12, "w": 24, "h": 10 },
      "targets": [
        {
          "datasource": { "type": "loki" },
          "expr": "{job=\"fluent-sandbox\"}"
        }
      ]
    }
  ]
}
